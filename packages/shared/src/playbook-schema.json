{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kora.dev/schemas/playbook-v1.json",
  "title": "Kora Playbook Schema",
  "description": "JSON Schema for Kora YAML playbook format",
  "type": "object",
  "required": ["name", "description", "agents"],
  "properties": {
    "version": {
      "type": "number",
      "const": 1,
      "description": "Schema version (currently 1)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Playbook name (required)"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Playbook description (required)"
    },
    "author": {
      "type": "string",
      "description": "Author email or name (optional)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorization (optional)"
    },
    "defaults": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["claude-code", "aider", "codex", "kiro", "goose"],
          "description": "Default CLI provider"
        },
        "model": {
          "type": "string",
          "description": "Default model for agents"
        },
        "worktreeMode": {
          "type": "string",
          "enum": ["isolated", "shared"],
          "description": "Default worktree mode"
        },
        "messagingMode": {
          "type": "string",
          "enum": ["mcp", "terminal", "manual"],
          "description": "Default messaging mode"
        }
      },
      "additionalProperties": false
    },
    "variables": {
      "type": "object",
      "description": "Variables prompted at launch for interpolation",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "description": "Variable description shown to user"
            },
            "type": {
              "type": "string",
              "enum": ["string", "number", "boolean"],
              "default": "string",
              "description": "Variable type"
            },
            "default": {
              "description": "Default value if not provided"
            },
            "enum": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Allowed values (dropdown options)"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "description": "Agents to spawn (at least one required)",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Agent name (required, unique)"
          },
          "role": {
            "type": "string",
            "enum": ["master", "worker"],
            "description": "Agent role: master (orchestrator) or worker"
          },
          "model": {
            "type": "string",
            "description": "Model override (optional if defaults.model set)"
          },
          "persona": {
            "type": "string",
            "description": "Agent persona: 'builtin:name' for template or inline text"
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^#[a-z0-9-]+$"
            },
            "description": "Message channels agent subscribes to (e.g. ['#all', '#frontend'])"
          },
          "extraCliArgs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Extra CLI arguments (e.g. ['--dangerously-skip-permissions'])"
          },
          "envVars": {
            "type": "object",
            "patternProperties": {
              "^[A-Z_][A-Z0-9_]*$": {
                "type": "string"
              }
            },
            "description": "Environment variables for agent"
          },
          "budgetLimit": {
            "type": "number",
            "minimum": 0,
            "description": "Budget limit in USD (optional)"
          },
          "initialTask": {
            "type": "string",
            "description": "Initial task message sent after spawn (optional)"
          }
        },
        "additionalProperties": false
      }
    },
    "tasks": {
      "type": "array",
      "description": "Tasks to create on task board at launch (optional)",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "Task title"
          },
          "description": {
            "type": "string",
            "description": "Task description (optional)"
          },
          "assignedTo": {
            "type": "string",
            "description": "Agent name to assign task to (optional)"
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"],
            "description": "Task priority (P0=critical, P1=high, P2=normal, P3=low)"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Task labels (optional)"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Task IDs this task depends on (optional)"
          }
        },
        "additionalProperties": false
      }
    },
    "worktreeMode": {
      "type": "string",
      "enum": ["isolated", "shared"],
      "description": "Worktree mode override (overrides defaults.worktreeMode)"
    },
    "messagingMode": {
      "type": "string",
      "enum": ["mcp", "terminal", "manual"],
      "description": "Messaging mode override (overrides defaults.messagingMode)"
    },
    "budget": {
      "type": "number",
      "minimum": 0,
      "description": "Total session budget in USD (optional)"
    }
  },
  "additionalProperties": false
}
